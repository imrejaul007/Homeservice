{
  "name": "home-service-backend",
  "version": "1.0.0",
  "description": "Backend API for Home Service Marketplace",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest --config jest.config.js",
    "test:ci": "jest --config jest.config.js --coverage --coverageThreshold='{\"global\":{\"branches\":70,\"functions\":70,\"lines\":70,\"statements\":70}}'",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.config.js --testPathPattern=integration",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts",
    "db:seed": "ts-node src/seeders/index.ts",
    "db:seed:services": "ts-node -e \"import './src/seeders/services.seeder'\".then(() => process.exit(0))",
    "db:seed:beauty": "ts-node src/scripts/seed-beauty.ts",
    "redis:cleanup-locks": "node scripts/cleanup-stale-locks.js",
    "db:create-admin": "ts-node src/scripts/create-admin.ts",
    "db:create-production-admin": "ts-node src/scripts/create-production-admin.ts",
    "db:reset": "ts-node src/scripts/reset-db.ts",
    "db:stats": "ts-node src/scripts/db-stats.ts",
    "db:health": "ts-node src/scripts/db-health.ts",
    "db:validate": "ts-node src/scripts/db-validate.ts",
    "db:test": "ts-node src/scripts/test-connection.ts",
    "db:optimize": "ts-node src/scripts/optimize-db.ts",
    "db:backup": "ts-node src/scripts/backup-db.ts",
    "db:backup:list": "ts-node src/scripts/backup-db.ts list",
    "db:restore": "ts-node src/scripts/backup-db.ts restore",
    "migrate:services": "ts-node src/scripts/migrate-services.ts",
    "migrate:verify": "ts-node src/scripts/migrate-services.ts verify"
  },
  "dependencies": {
    "@sentry/node": "^10.52.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/socket.io": "^3.0.1",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.7",
    "cloudinary": "^1.41.1",
    "compression": "^1.7.4",
    "cors": "^2.8.6",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.4.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.3.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^7.2.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.10.1",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "meilisearch": "^0.58.0",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.6",
    "opossum": "^9.0.0",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "resend": "^2.0.0",
    "socket.io": "^4.8.3",
    "speakeasy": "^2.0.0",
    "stripe": "^14.25.0",
    "swagger-jsdoc": "^6.2.0",
    "swagger-ui-express": "^5.0.0",
    "twilio": "^6.0.2",
    "uuid": "^14.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-serve-static-core": "^5.1.1",
    "@types/hpp": "^0.2.7",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/opossum": "^8.1.9",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^8.16.1",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
