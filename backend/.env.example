# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Database
MONGODB_URI=mongodb://localhost:27017/home_service_marketplace
# For MongoDB Atlas, use:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/home_service_marketplace?retryWrites=true&w=majority

# Security - Industry Standard JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ACCESS_SECRET=your-access-token-secret-key-ultra-secure-change-in-production
JWT_REFRESH_SECRET=your-refresh-token-secret-key-ultra-secure-change-in-production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=30d
JWT_REFRESH_ROTATE=true
BCRYPT_SALT_ROUNDS=12

# Session Security
CSRF_SECRET=your-csrf-secret-key-change-in-production
SESSION_TIMEOUT=15m
TOKEN_ROTATION=true
SECURITY_AUDIT=true

# CORS
CLIENT_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CAPTCHA (hCaptcha or reCAPTCHA) - Prevents brute force and bot attacks on auth endpoints
# Set CAPTCHA_ENABLED=true and add your keys to enable
CAPTCHA_ENABLED=false
# Provider: 'hcaptcha' or 'recaptcha'
CAPTCHA_PROVIDER=hcaptcha
# hCaptcha keys (https://www.hcaptcha.com/)
HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
HCAPTCHA_SECRET_KEY=your_hcaptcha_secret_key
# reCAPTCHA keys alternative (https://www.google.com/recaptcha)
# RECAPTCHA_SITE_KEY=your_recaptcha_site_key
# RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
# For reCAPTCHA v3, set minimum score threshold (0.0 - 1.0, higher = stricter)
CAPTCHA_SCORE_THRESHOLD=0.5

# File Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
MAX_FILE_SIZE=5242880

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_SUCCESS_URL=http://localhost:5173/payment-success
STRIPE_CANCEL_URL=http://localhost:5173/payment-cancel

# Stripe Price IDs (create these in your Stripe Dashboard)
# Format: price_<plan>_<billing_cycle>
# Example: STRIPE_PRICE_BASIC_MONTHLY=price_abc123basicmonthly
STRIPE_PRICE_BASIC_MONTHLY=price_your_basic_monthly_price_id
STRIPE_PRICE_BASIC_YEARLY=price_your_basic_yearly_price_id
STRIPE_PRICE_PREMIUM_MONTHLY=price_your_premium_monthly_price_id
STRIPE_PRICE_PREMIUM_YEARLY=price_your_premium_yearly_price_id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_your_enterprise_monthly_price_id
STRIPE_PRICE_ENTERPRISE_YEARLY=price_your_enterprise_yearly_price_id

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_REPLY_TO=support@yourdomain.com

# Email (SMTP - Alternative to Resend)
# If SMTP is configured, it will be used as the primary email method
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@nilin.com
FROM_NAME=NILIN

# Redis (for email queue processing)
REDIS_URL=redis://localhost:6379
# For Redis Cloud, use:
# REDIS_URL=redis-xxxxx.cxxx.xx-x-x.ec2.cloud.redislabs.com:xxxxx

# Logging
LOG_LEVEL=debug
LOG_FILE_PATH=logs/app.log

# Session
SESSION_SECRET=your-session-secret-key
SESSION_EXPIRY=86400000

# External APIs (Optional)
OPENCAGE_API_KEY=your_opencage_api_key_here
GOOGLE_MAPS_API_KEY=your_google_maps_key
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase Admin SDK (for push notifications)
# Option 1: Path to service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=/path/to/firebase-service-account.json
# Option 2: JSON string directly in env (for deployment platforms)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}
FIREBASE_PROJECT_ID=your-firebase-project-id

# Frontend URL (for unsubscribe links, email templates)
FRONTEND_URL=https://your-frontend-url.com

# Error Tracking (Sentry)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
APP_NAME=HomeService
APP_VERSION=1.0.0