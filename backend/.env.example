# ============================================================
# AI Service Configuration
# ============================================================

# AI Provider: openai, anthropic, or none (for rule-based only)
AI_PROVIDER=none

# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500
OPENAI_TEMPERATURE=0.7
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude Configuration
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-haiku-20240307
ANTHROPIC_MAX_TOKENS=500
ANTHROPIC_TEMPERATURE=0.7
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# Rate Limiting
AI_RATE_LIMIT_PER_MINUTE=60
AI_RATE_LIMIT_PER_HOUR=1000
AI_TOKEN_RATE_LIMIT=100000

# Timeouts (in milliseconds)
AI_REQUEST_TIMEOUT_MS=30000
AI_TOTAL_TIMEOUT_MS=35000

# Circuit Breaker Configuration
AI_CB_FAILURE_THRESHOLD=5
AI_CB_RESET_TIMEOUT_MS=30000
AI_CB_HALF_OPEN_ATTEMPTS=2

# Response Caching
AI_CACHE_ENABLED=true
AI_CACHE_TTL_SECONDS=3600
AI_CACHE_MAX_ENTRIES=1000

# Email unsubscribe token signing (required in production)
UNSUBSCRIBE_SECRET=

# ============================================================
# Geocoding & Location Services
# ============================================================

# Google Maps API Key (primary geocoding provider)
# Get from: https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# OpenCage API Key (fallback geocoding provider)
# Get from: https://opencagedata.com/
OPENCAGE_API_KEY=
