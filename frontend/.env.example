VITE_API_URL=http://localhost:5000/api
VITE_APP_NAME=Home Service Marketplace
VITE_APP_VERSION=1.0.0
VITE_ENVIRONMENT=development

# Currency Configuration
VITE_CURRENCY_CODE=AED
VITE_CURRENCY_SYMBOL=د.إ

# Location Services (geocoding runs via backend OPENCAGE_API_KEY — no frontend key required)
VITE_OPENCAGE_API_KEY=your_opencage_api_key_here
VITE_DEFAULT_LOCATION_LAT=25.2048
VITE_DEFAULT_LOCATION_LNG=55.2708
VITE_DEFAULT_LOCATION_NAME=Dubai