{
  "appId": "com.nilin.app",
  "appName": "NILIN",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "url": "https://homeservice-1.onrender.com"
  },
  "android": {
    "backgroundColor": "#F5E6E0",
    "webContentsDebuggingEnabled": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#F5E6E0",
      "showSpinner": true,
      "spinnerColor": "#E8B4A8",
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#2D2D2D",
      "overlaysWebView": false
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK",
      "scrollPadding": true
    }
  }
}
