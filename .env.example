# Backend Environment Variables
NODE_ENV=production
PORT=10000

# Database
MONGODB_URI=mongodb://mongodb:27017/home_service_marketplace

# JWT Security (Generate secure values for production)
JWT_SECRET=generate-a-secure-64-char-random-string
JWT_ACCESS_SECRET=generate-another-secure-64-char-random-string
JWT_REFRESH_SECRET=generate-yet-another-secure-64-char-random-string

# Session Security
CSRF_SECRET=generate-a-secure-random-string

# Payment (Stripe)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# File Upload (Cloudinary)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email (Resend)
RESEND_API_KEY=re_...

# Sentry
SENTRY_DSN=https://...@sentry.io/...

# Frontend
VITE_SENTRY_DSN=https://...@sentry.io/...
